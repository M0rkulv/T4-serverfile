			"string"
			{
				"Digital Distribution"		"Steam"
				"EXEStringM"		"%INSTALLDIR%\\CoDWaWmp.exe"
				"EXEStringS"		"%INSTALLDIR%\\CoDWaW.exe"
				"InstallDrive"		"%INSTALLDIR%"
				"InstallPath"		"%INSTALLDIR%"
				"PatchLog"		"%INSTALLDIR%\\install.log"
				"Techhelp"		"%INSTALLDIR%\\Docs\\Help\\readme.htm"
				"Version"		"1.3 "
				"english"
				{
					"Language"		"enu"
					"QA"		"22.0 "
