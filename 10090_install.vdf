				"italian"
				{
					"Language"		"ita"
					"QA"		"4.0 "
				}
			}
		}
	}
	"Run Process"
	{
		"DirectX"
		{
			"process 1"		"%INSTALLDIR%\\DirectX\\DXSETUP.exe"
			"NoCleanUp"		"1"
			"IgnoreExitCode"		"1"
		}
		"Punkbuster"
		{
			"process 1"		"%INSTALLDIR%\\installers\\pbsvc.exe"
			"command 1"		"/i"
			"IgnoreExitCode"		"1"
			"NoCleanUp"		"1"
		}
	}
}
